{
    "name": "vaslv/filament-topbar-menu",
    "description": "A configurable topbar menu plugin for Filament 5 — external and internal links, dropdowns, favicons, caching.",
    "keywords": [
        "laravel",
        "filament",
        "filament-plugin",
        "topbar",
        "menu",
        "navigation"
    ],
    "homepage": "https://github.com/vaslv/filament-topbar-menu",
    "license": "MIT",
    "authors": [
        {
            "name": "Andrei Vasilev",
            "email": "andrei@vaslv.ru"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^10.0|^11.0",
        "phpunit/phpunit": "^11.5|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Vaslv\\FilamentTopbarMenu\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vaslv\\FilamentTopbarMenu\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "analyse": "vendor/bin/phpstan analyse",
        "lint": "vendor/bin/pint",
        "lint:test": "vendor/bin/pint --test",
        "check": [
            "@lint:test",
            "@analyse",
            "@test"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Vaslv\\FilamentTopbarMenu\\TopbarMenuServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
